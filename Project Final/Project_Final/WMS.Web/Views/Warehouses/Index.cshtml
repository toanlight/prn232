@model List<WMS.Web.Controllers.WarehouseViewModel>
@{
    ViewData["Title"] = "Danh sách Kho Hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">Danh sách Kho Hàng</h4>
        <p class="text-muted fs-7 mb-0">Quản lý kho vật lý và sơ đồ lưu trữ</p>
    </div>
    <button class="btn btn-primary btn-sm px-3 fw-semibold" data-bs-toggle="modal" data-bs-target="#createWarehouseModal">
        <i class="fa-solid fa-plus me-1"></i> Thêm Kho Hàng
    </button>
</div>

<div class="row g-3">
    @if (Model != null && Model.Any())
    {
        foreach (var wh in Model)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card-wms p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="kpi-icon kpi-blue">
                                <i class="fa-solid fa-warehouse"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0 text-dark">@wh.Name</h6>
                                <span class="badge bg-light text-secondary border">Mã: @wh.Code</span>
                            </div>
                        </div>
                        <span class="badge @(wh.IsActive ? "bg-success" : "bg-secondary")">@(wh.IsActive ? "Hoạt động" : "Ngừng")</span>
                    </div>

                    <p class="text-muted fs-7 mb-3"><i class="fa-solid fa-location-dot me-1"></i>@(wh.Address ?? "Chưa cập nhật địa chỉ")</p>

                    <div class="d-flex gap-2 pt-2 border-top">
                        <a href="/Warehouses/@wh.Id/Structure" class="btn btn-sm btn-outline-primary flex-grow-1 fw-semibold">
                            <i class="fa-solid fa-sitemap me-1"></i> Sơ đồ Cây Kho
                        </a>
                        <a href="/Warehouses/@wh.Id/Zones" class="btn btn-sm btn-light border fw-semibold">
                            <i class="fa-solid fa-layer-group me-1"></i> Quản lý Zone
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card-wms p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon kpi-blue">
                            <i class="fa-solid fa-warehouse"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0 text-dark">Kho Tổng Trung Tâm</h6>
                            <span class="badge bg-light text-secondary border">Mã: WH-CENTRAL</span>
                        </div>
                    </div>
                    <span class="badge bg-success">Hoạt động</span>
                </div>
                <p class="text-muted fs-7 mb-3"><i class="fa-solid fa-location-dot me-1"></i>Lô C4, KCN Tân Bình, TP.HCM</p>
                <div class="d-flex gap-2 pt-2 border-top">
                    <a href="/Warehouses/1/Structure" class="btn btn-sm btn-outline-primary flex-grow-1 fw-semibold">
                        <i class="fa-solid fa-sitemap me-1"></i> Sơ đồ Cây Kho
                    </a>
                    <a href="/Warehouses/1/Zones" class="btn btn-sm btn-light border fw-semibold">
                        <i class="fa-solid fa-layer-group me-1"></i> Quản lý Zone
                    </a>
                </div>
            </div>
        </div>
    }
</div>
