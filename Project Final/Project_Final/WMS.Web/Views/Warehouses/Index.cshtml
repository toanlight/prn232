@model WMS.Web.Models.PagedResponseModel<WMS.Web.Models.WarehouseItemViewModel>
@{
    ViewData["Title"] = "Danh sách Kho Hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">Danh sách Kho Hàng</h4>
        <p class="text-muted fs-7 mb-0">Quản lý kho vật lý và sơ đồ lưu trữ 5 cấp</p>
    </div>
</div>

<div class="row g-3">
    @if (Model.Data != null && Model.Data.Any())
    {
        foreach (var wh in Model.Data)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card-wms p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="kpi-icon kpi-blue">
                                <i class="fa-solid fa-warehouse"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0 text-dark">@wh.Name</h6>
                                <span class="badge bg-light text-secondary border">Mã: @wh.Code</span>
                            </div>
                        </div>
                        <span class="badge @(wh.IsActive ? "bg-success" : "bg-secondary")">@(wh.IsActive ? "Hoạt động" : "Ngừng")</span>
                    </div>

                    <p class="text-muted fs-7 mb-3"><i class="fa-solid fa-location-dot me-1"></i>@(wh.Address ?? "Chưa cập nhật địa chỉ")</p>

                    <div class="d-flex gap-2 pt-2 border-top">
                        <a href="/Warehouses/@wh.Id/Structure" class="btn btn-sm btn-outline-primary flex-grow-1 fw-semibold">
                            <i class="fa-solid fa-sitemap me-1"></i> Xem Sơ đồ Cây Kho
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5 text-muted">
            <i class="fa-solid fa-warehouse fs-1 mb-2 d-block text-secondary"></i>
            Chưa có kho hàng nào được khởi tạo.
        </div>
    }
</div>
