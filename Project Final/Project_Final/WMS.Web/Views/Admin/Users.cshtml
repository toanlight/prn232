@model WMS.Web.Models.PagedResponseModel<WMS.Web.Models.UserItemViewModel>
@{
    ViewData["Title"] = "Quản lý Người dùng System";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">Quản lý Người dùng & Phân quyền</h4>
        <p class="text-muted fs-7 mb-0">Danh sách tài khoản người dùng thực tế trong hệ thống WMS</p>
    </div>
</div>

<div class="card-wms p-4">
    <table class="table table-hover align-middle fs-7">
        <thead class="table-light">
            <tr>
                <th>Username</th>
                <th>Họ và tên</th>
                <th>Email</th>
                <th>Điện thoại</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Data != null && Model.Data.Any())
            {
                @foreach (var user in Model.Data)
                {
                    <tr>
                        <td class="fw-bold text-primary">@user.Username</td>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@(user.Phone ?? "---")</td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Khóa</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">
                        <i class="fa-solid fa-users-slash fs-3 mb-2 d-block"></i>
                        Chưa có dữ liệu người dùng nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
