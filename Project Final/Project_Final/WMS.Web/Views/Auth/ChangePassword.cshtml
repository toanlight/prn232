@{
    ViewData["Title"] = "Đổi mật khẩu";
}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card card-wms">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="card-title fw-bold mb-0"><i class="fa-solid fa-key text-primary me-2"></i>Đổi mật khẩu tài khoản</h5>
            </div>
            <div class="card-body p-4">
                <form id="changePasswordForm">
                    <div class="mb-3">
                        <label class="form-label fs-7 fw-semibold">Mật khẩu hiện tại</label>
                        <input type="password" id="oldPassword" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fs-7 fw-semibold">Mật khẩu mới</label>
                        <input type="password" id="newPassword" class="form-control" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fs-7 fw-semibold">Xác nhận mật khẩu mới</label>
                        <input type="password" id="confirmPassword" class="form-control" required />
                    </div>
                    <button type="button" onclick="submitChangePassword()" class="btn btn-primary w-100 py-2 fw-semibold">
                        Cập nhật mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function submitChangePassword() {
        const oldPassword = document.getElementById('oldPassword').value;
        const newPassword = document.getElementById('newPassword').value;
        const confirmPassword = document.getElementById('confirmPassword').value;

        if (newPassword !== confirmPassword) {
            WMS.showToast('Mật khẩu xác nhận không trùng khớp.', 'warning');
            return;
        }

        WMS.showToast('Đổi mật khẩu thành công!', 'success');
    }
</script>
}
