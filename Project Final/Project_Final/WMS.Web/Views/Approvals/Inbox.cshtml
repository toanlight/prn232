@model List<WMS.Web.Models.ApprovalItemViewModel>
@{
    ViewData["Title"] = "Hộp thư Phê duyệt";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">Hộp thư Phê duyệt (Approval Inbox)</h4>
        <p class="text-muted fs-7 mb-0">Xem & Phê duyệt nhanh chứng từ Nhập (GRN), Xuất (GDN), Chuyển kho & Điều chỉnh</p>
    </div>
</div>

<div class="card-wms p-4">
    <table class="table table-hover align-middle fs-7">
        <thead class="table-light">
            <tr>
                <th>Loại chứng từ</th>
                <th>Mã chứng từ (ID)</th>
                <th>Cấp phê duyệt</th>
                <th>Ghi chú / Nội dung</th>
                <th>Ngày tạo</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="badge bg-primary-subtle text-primary border border-primary">@item.DocumentType.ToUpper()</span>
                        </td>
                        <td class="fw-bold">#@item.DocumentId</td>
                        <td>
                            <span class="badge bg-warning text-dark">Lấp @item.Level</span>
                        </td>
                        <td>@(item.Comment ?? "Không có ghi chú")</td>
                        <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="badge bg-info">@item.Status</span>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">
                        <i class="fa-solid fa-circle-check fs-3 mb-2 d-block text-success"></i>
                        Không có chứng từ nào đang chờ phê duyệt.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
