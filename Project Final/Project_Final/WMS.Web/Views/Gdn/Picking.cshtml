@{
    ViewData["Title"] = "Màn hình Picking Kho: GDN-2026-0089";
}

<!-- Optimized for Mobile / Tablet Warehouse Workers -->
<div class="card-wms p-4 mb-4 border-primary">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <div>
            <h3 class="fw-bold text-primary mb-1"><i class="fa-solid fa-hand-holding-box me-2"></i>PICKING: GDN-2026-0089</h3>
            <p class="text-muted fs-6 mb-0">Khách hàng: <strong>Chuỗi Siêu thị Mega Market</strong> | Kho xuất: <strong>Kho A</strong></p>
        </div>
        <div class="text-end">
            <span class="badge bg-primary fs-6 px-3 py-2">TIẾN ĐỘ: <span id="progressPercent">50%</span></span>
        </div>
    </div>

    <!-- Progress bar -->
    <div class="progress mb-3" style="height: 12px;">
        <div id="pickingProgressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar" style="width: 50%;"></div>
    </div>
</div>

<!-- Picking Task Lines (Large Font, Clear Location Display) -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card-wms p-4 bg-light border-warning border-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="badge bg-warning text-dark fs-6 mb-2">ĐÓNG BĂNG VỊ TRÍ 1</span>
                    <h2 class="fw-extrabold text-danger mb-1 display-6">VỊ TRÍ: WH1-ZA-R1-S1-B01</h2>
                    <h4 class="fw-bold text-dark mt-2">SKU-FOOD-001 - Sữa tươi tiệt trùng 1L</h4>
                    <p class="fs-5 text-secondary mb-0">Lô: <strong class="text-dark">LOT-2026-0815</strong> (HSD: 15/08/2026)</p>
                </div>
                <div class="text-end">
                    <div class="fs-7 text-muted uppercase">SỐ LƯỢNG CẦN LẤY</div>
                    <div class="display-4 fw-bold text-primary">50 <span class="fs-5">Hộp</span></div>
                </div>
            </div>

            <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                <div class="form-check form-check-inline fs-5 fw-bold">
                    <input class="form-check-input" type="checkbox" id="line1Check" onchange="updatePickingProgress()" style="width: 25px; height: 25px;" />
                    <label class="form-check-label ms-2 text-success" for="line1Check">XÁC NHẬN ĐÃ LẤY ĐỦ 50 HỘP</label>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card-wms p-4 bg-light border-secondary">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="badge bg-secondary fs-6 mb-2">VỊ TRÍ 2</span>
                    <h2 class="fw-bold text-dark mb-1">VỊ TRÍ: WH1-ZA-R1-S2-B02</h2>
                    <h4 class="fw-bold text-dark mt-2">SKU-BEV-009 - Nước ép cam 500ml</h4>
                    <p class="fs-5 text-secondary mb-0">Lô: <strong class="text-dark">LOT-2026-0910</strong> (HSD: 10/09/2026)</p>
                </div>
                <div class="text-end">
                    <div class="fs-7 text-muted uppercase">SỐ LƯỢNG CẦN LẤY</div>
                    <div class="display-4 fw-bold text-primary">30 <span class="fs-5">Chai</span></div>
                </div>
            </div>

            <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                <div class="form-check form-check-inline fs-5 fw-bold">
                    <input class="form-check-input" type="checkbox" id="line2Check" onchange="updatePickingProgress()" style="width: 25px; height: 25px;" />
                    <label class="form-check-label ms-2 text-success" for="line2Check">XÁC NHẬN ĐÃ LẤY ĐỦ 30 CHAI</label>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center">
    <a href="/Gdn" class="btn btn-outline-secondary btn-lg px-4">Tạm dừng</a>
    <button type="button" id="btnCompletePicking" class="btn btn-success btn-lg px-5 fw-bold shadow-lg" onclick="finishPicking()" disabled>
        <i class="fa-solid fa-circle-check me-2"></i> HOÀN THÀNH PICKING KHO
    </button>
</div>

@section Scripts {
<script>
    function updatePickingProgress() {
        const c1 = document.getElementById('line1Check').checked;
        const c2 = document.getElementById('line2Check').checked;

        let checkedCount = (c1 ? 1 : 0) + (c2 ? 1 : 0);
        let pct = (checkedCount / 2) * 100;

        document.getElementById('pickingProgressBar').style.width = pct + '%';
        document.getElementById('progressPercent').innerText = pct + '%';

        const btn = document.getElementById('btnCompletePicking');
        if (pct === 100) {
            btn.disabled = false;
            btn.classList.add('animate-bounce');
        } else {
            btn.disabled = true;
        }
    }

    function finishPicking() {
        WMS.showToast('Đã hoàn tất lấy hàng (Picking) cho phiếu GDN-2026-0089!', 'success');
        setTimeout(() => location.href = '/Gdn', 1200);
    }
</script>
}
