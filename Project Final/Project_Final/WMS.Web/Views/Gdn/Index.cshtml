                <td class="text-center">
                    <a href="/Gdn/Picking/1" class="btn btn-sm btn-warning fw-semibold"><i class="fa-solid fa-hand-holding-hand me-1"></i> Màn hình Picking</a>
                    <a href="/Gdn/Detail/1" class="btn btn-sm btn-light border text-primary ms-1"><i class="fa-solid fa-eye"></i></a>
