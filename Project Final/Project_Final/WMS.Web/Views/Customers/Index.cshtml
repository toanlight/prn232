@model WMS.Web.Models.PagedResponseModel<WMS.Web.Models.CustomerItemViewModel>
@{
    ViewData["Title"] = "Khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">Quản lý Khách hàng</h4>
        <p class="text-muted fs-7 mb-0">Danh sách khách hàng, đối tác, hợp đồng & thông tin liên hệ</p>
    </div>
    <button class="btn btn-primary btn-sm px-3 fw-semibold" data-bs-toggle="modal" data-bs-target="#createCustomerModal">
        <i class="fa-solid fa-plus me-1"></i> Thêm Khách hàng
    </button>
</div>

<div class="card-wms p-4">
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-4">
            <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm" placeholder="Tìm kiếm theo mã, tên, SĐT, MST...">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-secondary btn-sm w-100"><i class="fa-solid fa-magnifying-glass me-1"></i> Tìm kiếm</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle fs-7 text-nowrap">
            <thead class="table-light">
                <tr>
                    <th>Mã KH</th>
                    <th>Tên Khách hàng</th>
                    <th>Loại KH</th>
                    <th>Mã số thuế</th>
                    <th>Địa chỉ</th>
                    <th>Email</th>
                    <th>Điện thoại</th>
                    <th>Người liên hệ</th>
                    <th>SĐT người liên hệ</th>
                    <th>Số hợp đồng</th>
                    <th>Ngày BĐ hợp đồng</th>
                    <th>Ngày KT hợp đồng</th>
                    <th>Điều khoản dịch vụ</th>
                    <th>Ghi chú</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Người tạo</th>
                    <th>Ngày cập nhật</th>
                    <th>Người cập nhật</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data != null && Model.Data.Any())
                {
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="fw-bold text-primary">@item.Code</td>
                            <td>@item.Name</td>
                            <td>
                                @if (item.CustomerType == "B2BService" || item.CustomerType == "0")
                                {
                                    <span class="badge bg-info text-dark">Dịch vụ B2B</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">Consignee</span>
                                }
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(item.TaxCode) ? "N/A" : item.TaxCode)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Address) ? "N/A" : item.Address)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Email) ? "N/A" : item.Email)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Phone) ? "N/A" : item.Phone)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ContactPerson) ? "N/A" : item.ContactPerson)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ContactPhone) ? "N/A" : item.ContactPhone)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ContractNumber) ? "N/A" : item.ContractNumber)</td>
                            <td>@(item.ContractStartDate.HasValue ? item.ContractStartDate.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                            <td>@(item.ContractEndDate.HasValue ? item.ContractEndDate.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ServiceTerms) ? "N/A" : item.ServiceTerms)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Notes) ? "N/A" : item.Notes)</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ngừng hoạt động</span>
                                }
                            </td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.CreatedBy) ? "N/A" : item.CreatedBy)</td>
                            <td>@(item.UpdatedAt.HasValue ? item.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.UpdatedBy) ? "N/A" : item.UpdatedBy)</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary me-1 py-0 px-2"
                                        onclick="openEditModalFromBtn(this)"
                                        data-id="@item.Id"
                                        data-code="@item.Code"
                                        data-name="@item.Name"
                                        data-customertype="@item.CustomerType"
                                        data-taxcode="@item.TaxCode"
                                        data-address="@item.Address"
                                        data-email="@item.Email"
                                        data-phone="@item.Phone"
                                        data-contactperson="@item.ContactPerson"
                                        data-contactphone="@item.ContactPhone"
                                        data-contractnumber="@item.ContractNumber"
                                        data-contractstart="@(item.ContractStartDate.HasValue ? item.ContractStartDate.Value.ToString("yyyy-MM-dd") : "")"
                                        data-contractend="@(item.ContractEndDate.HasValue ? item.ContractEndDate.Value.ToString("yyyy-MM-dd") : "")"
                                        data-serviceterms="@item.ServiceTerms"
                                        data-notes="@item.Notes"
                                        data-isactive="@(item.IsActive ? "true" : "false")"
                                        title="Chỉnh sửa">
                                    <i class="fa-solid fa-pen-to-square me-1"></i>Sửa
                                </button>
                                <button class="btn btn-sm btn-outline-danger py-0 px-2" onclick="confirmDeleteCustomer(@item.Id, '@item.Name')" title="Xóa khách hàng">
                                    <i class="fa-solid fa-trash me-1"></i>Xóa
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="20" class="text-center py-4 text-muted">
                            <i class="fa-solid fa-inbox fs-3 mb-2 d-block"></i>
                            Chưa có dữ liệu khách hàng nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model != null && Model.TotalCount > 0)
    {
        <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
            <div class="fs-7 text-muted">
                Hiển thị <span class="fw-bold text-dark">@Model.Items.Count</span> / <span class="fw-bold text-dark">@Model.TotalCount</span> Khách hàng
            </div>
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link" href="/Customers?pageIndex=@(Model.PageIndex - 1)&keyword=@ViewBag.Keyword">
                                <i class="fa-solid fa-angle-left me-1"></i>Trước
                            </a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                <a class="page-link" href="/Customers?pageIndex=@i&keyword=@ViewBag.Keyword">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link" href="/Customers?pageIndex=@(Model.PageIndex + 1)&keyword=@ViewBag.Keyword">
                                Tiếp<i class="fa-solid fa-angle-right ms-1"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    }
</div>

<!-- Modal Thêm Khách hàng -->
<div class="modal fade" id="createCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Thêm mới Khách hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body fs-7">
                <form id="createCustomerForm" class="row g-2">
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Mã KH *</label>
                        <input type="text" id="custCode" class="form-control form-control-sm" required placeholder="VD: CUST-001">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Tên Khách hàng *</label>
                        <input type="text" id="custName" class="form-control form-control-sm" required placeholder="VD: Siêu thị VinMart">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Loại Khách hàng *</label>
                        <select id="custType" class="form-select form-select-sm" required>
                            <option value="Consignee">Consignee (Người nhận hàng)</option>
                            <option value="B2BService">Dịch vụ B2B</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Mã số thuế</label>
                        <input type="text" id="custTaxCode" class="form-control form-control-sm" placeholder="VD: 0101234567">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Điện thoại</label>
                        <input type="text" id="custPhone" class="form-control form-control-sm" placeholder="VD: 0901234567">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Email</label>
                        <input type="email" id="custEmail" class="form-control form-control-sm" placeholder="contact@khachhang.com">
                    </div>
                    <div class="col-md-12 mb-2">
                        <label class="form-label fw-semibold mb-1">Địa chỉ</label>
                        <input type="text" id="custAddress" class="form-control form-control-sm" placeholder="Số nhà, Tên đường, Quận/Huyện, Tỉnh/TP">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Người liên hệ</label>
                        <input type="text" id="custContactPerson" class="form-control form-control-sm" placeholder="VD: Trần Văn B">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">SĐT người liên hệ</label>
                        <input type="text" id="custContactPhone" class="form-control form-control-sm" placeholder="VD: 0912345678">
                    </div>
                    <div class="col-md-4 mb-2">
                        <label class="form-label fw-semibold mb-1">Số hợp đồng</label>
                        <input type="text" id="custContractNumber" class="form-control form-control-sm" placeholder="VD: HD-2026-CUST">
                    </div>
                    <div class="col-md-4 mb-2">
                        <label class="form-label fw-semibold mb-1">Ngày BĐ hợp đồng</label>
                        <input type="date" id="custContractStartDate" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-4 mb-2">
                        <label class="form-label fw-semibold mb-1">Ngày KT hợp đồng</label>
                        <input type="date" id="custContractEndDate" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Điều khoản dịch vụ</label>
                        <input type="text" id="custServiceTerms" class="form-control form-control-sm" placeholder="VD: Thanh toán trong 15 ngày">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Ghi chú</label>
                        <input type="text" id="custNotes" class="form-control form-control-sm" placeholder="Ghi chú thêm...">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
                <button type="button" onclick="submitCreateCustomer()" class="btn btn-primary btn-sm">Lưu Khách Hàng</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Cập nhật Khách hàng -->
<div class="modal fade" id="editCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Cập nhật Khách hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body fs-7">
                <form id="editCustomerForm" class="row g-2">
                    <input type="hidden" id="editCustId">
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Mã KH</label>
                        <input type="text" id="editCustCode" class="form-control form-control-sm" disabled>
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Tên Khách hàng *</label>
                        <input type="text" id="editCustName" class="form-control form-control-sm" required>
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Loại Khách hàng *</label>
                        <select id="editCustType" class="form-select form-select-sm" required>
                            <option value="Consignee">Consignee (Người nhận hàng)</option>
                            <option value="B2BService">Dịch vụ B2B</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Mã số thuế</label>
                        <input type="text" id="editCustTaxCode" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Điện thoại</label>
                        <input type="text" id="editCustPhone" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Email</label>
                        <input type="email" id="editCustEmail" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-12 mb-2">
                        <label class="form-label fw-semibold mb-1">Địa chỉ</label>
                        <input type="text" id="editCustAddress" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Người liên hệ</label>
                        <input type="text" id="editCustContactPerson" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">SĐT người liên hệ</label>
                        <input type="text" id="editCustContactPhone" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-4 mb-2">
                        <label class="form-label fw-semibold mb-1">Số hợp đồng</label>
                        <input type="text" id="editCustContractNumber" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-4 mb-2">
                        <label class="form-label fw-semibold mb-1">Ngày BĐ hợp đồng</label>
                        <input type="date" id="editCustContractStartDate" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-4 mb-2">
                        <label class="form-label fw-semibold mb-1">Ngày KT hợp đồng</label>
                        <input type="date" id="editCustContractEndDate" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Điều khoản dịch vụ</label>
                        <input type="text" id="editCustServiceTerms" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Ghi chú</label>
                        <input type="text" id="editCustNotes" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold mb-1">Trạng thái *</label>
                        <select id="editCustIsActive" class="form-select form-select-sm">
                            <option value="true">Hoạt động</option>
                            <option value="false">Ngừng hoạt động</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
                <button type="button" onclick="submitUpdateCustomer()" class="btn btn-primary btn-sm">Cập nhật Khách Hàng</button>
            </div>
        </div>
    </div>
</div>

<script>
    async function submitCreateCustomer() {
        const payload = {
            code: document.getElementById('custCode').value,
            name: document.getElementById('custName').value,
            customerType: document.getElementById('custType').value,
            taxCode: document.getElementById('custTaxCode').value || null,
            address: document.getElementById('custAddress').value || null,
            email: document.getElementById('custEmail').value || null,
            phone: document.getElementById('custPhone').value || null,
            contactPerson: document.getElementById('custContactPerson').value || null,
            contactPhone: document.getElementById('custContactPhone').value || null,
            contractNumber: document.getElementById('custContractNumber').value || null,
            contractStartDate: document.getElementById('custContractStartDate').value || null,
            contractEndDate: document.getElementById('custContractEndDate').value || null,
            serviceTerms: document.getElementById('custServiceTerms').value || null,
            notes: document.getElementById('custNotes').value || null
        };

        try {
            const res = await fetch('/Customers/Create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (data.success) {
                const modalEl = document.getElementById('createCustomerModal');
                const modal = bootstrap.Modal.getInstance(modalEl);
                if (modal) modal.hide();

                WMS.showToast(data.message || 'Tạo khách hàng thành công!', 'success');
                setTimeout(() => location.reload(), 1200);
            } else {
                WMS.showToast(data.message || 'Có lỗi xảy ra', 'danger');
            }
        } catch (err) {
            WMS.showToast('Không thể gửi yêu cầu: ' + err.message, 'danger');
        }
    }

    function openEditModalFromBtn(btn) {
        document.getElementById('editCustId').value = btn.getAttribute('data-id') || '';
        document.getElementById('editCustCode').value = btn.getAttribute('data-code') || '';
        document.getElementById('editCustName').value = btn.getAttribute('data-name') || '';
        document.getElementById('editCustType').value = btn.getAttribute('data-customertype') || 'Consignee';
        document.getElementById('editCustTaxCode').value = btn.getAttribute('data-taxcode') || '';
        document.getElementById('editCustPhone').value = btn.getAttribute('data-phone') || '';
        document.getElementById('editCustEmail').value = btn.getAttribute('data-email') || '';
        document.getElementById('editCustAddress').value = btn.getAttribute('data-address') || '';
        document.getElementById('editCustContactPerson').value = btn.getAttribute('data-contactperson') || '';
        document.getElementById('editCustContactPhone').value = btn.getAttribute('data-contactphone') || '';
        document.getElementById('editCustContractNumber').value = btn.getAttribute('data-contractnumber') || '';
        document.getElementById('editCustContractStartDate').value = btn.getAttribute('data-contractstart') || '';
        document.getElementById('editCustContractEndDate').value = btn.getAttribute('data-contractend') || '';
        document.getElementById('editCustServiceTerms').value = btn.getAttribute('data-serviceterms') || '';
        document.getElementById('editCustNotes').value = btn.getAttribute('data-notes') || '';
        document.getElementById('editCustIsActive').value = btn.getAttribute('data-isactive') || 'true';

        const modal = new bootstrap.Modal(document.getElementById('editCustomerModal'));
        modal.show();
    }

    async function submitUpdateCustomer() {
        const id = document.getElementById('editCustId').value;
        const payload = {
            name: document.getElementById('editCustName').value,
            customerType: document.getElementById('editCustType').value,
            taxCode: document.getElementById('editCustTaxCode').value || null,
            address: document.getElementById('editCustAddress').value || null,
            email: document.getElementById('editCustEmail').value || null,
            phone: document.getElementById('editCustPhone').value || null,
            contactPerson: document.getElementById('editCustContactPerson').value || null,
            contactPhone: document.getElementById('editCustContactPhone').value || null,
            contractNumber: document.getElementById('editCustContractNumber').value || null,
            contractStartDate: document.getElementById('editCustContractStartDate').value || null,
            contractEndDate: document.getElementById('editCustContractEndDate').value || null,
            serviceTerms: document.getElementById('editCustServiceTerms').value || null,
            notes: document.getElementById('editCustNotes').value || null,
            isActive: document.getElementById('editCustIsActive').value === 'true'
        };

        try {
            const res = await fetch(`/Customers/Update/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (data.success) {
                const modalEl = document.getElementById('editCustomerModal');
                const modal = bootstrap.Modal.getInstance(modalEl);
                if (modal) modal.hide();

                WMS.showToast(data.message || 'Cập nhật thành công!', 'success');
                setTimeout(() => location.reload(), 1200);
            } else {
                WMS.showToast(data.message || 'Có lỗi xảy ra', 'danger');
            }
        } catch (err) {
            WMS.showToast('Không thể cập nhật: ' + err.message, 'danger');
        }
    }

    function confirmDeleteCustomer(id, name) {
        WMS.confirm('Xác nhận xóa khách hàng', `Bạn có chắc chắn muốn xóa khách hàng "${name}"?`, async () => {
            try {
                const res = await fetch(`/Customers/Delete/${id}`, {
                    method: 'POST'
                });
                const data = await res.json();
                if (data.success) {
                    WMS.showToast(data.message || 'Đã xóa khách hàng thành công!', 'success');
                    setTimeout(() => location.reload(), 1200);
                } else {
                    WMS.showToast(data.message || 'Có lỗi xảy ra', 'danger');
                }
            } catch (err) {
                WMS.showToast('Lỗi thao tác: ' + err.message, 'danger');
            }
        });
    }
</script>
