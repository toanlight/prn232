@model WMS.Web.Models.PagedResponseModel<WMS.Web.Models.BatchItemViewModel>
@{
    ViewData["Title"] = "Quản lý Lô & Hạn Sử Dụng";
    string currentTab = ViewBag.Tab ?? "all";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">Quản lý Lô & Hạn sử dụng</h4>
        <p class="text-muted fs-7 mb-0">Theo dõi số Lô (Lot/Batch), Hạn dùng (Expiry) & vị trí phân bổ</p>
    </div>
</div>

<ul class="nav nav-tabs mb-4" id="batchTabs">
    <li class="nav-item">
        <a class="nav-link @(currentTab == "all" ? "active fw-bold" : "")" href="/Batches?tab=all">
            <i class="fa-solid fa-list me-1"></i> Tất cả Lô
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentTab == "expiring" ? "active fw-bold text-warning" : "")" href="/Batches?tab=expiring">
            <i class="fa-solid fa-hourglass-half me-1"></i> Sắp hết hạn (<= 30 ngày)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentTab == "expired" ? "active fw-bold text-danger" : "")" href="/Batches?tab=expired">
            <i class="fa-solid fa-calendar-xmark me-1"></i> Đã quá hạn
        </a>
    </li>
</ul>

<div class="card-wms p-4">
    <table class="table table-hover align-middle fs-7">
        <thead class="table-light">
            <tr>
                <th>Số Lô (Lot Number)</th>
                <th>Sản phẩm</th>
                <th>Nhà cung cấp</th>
                <th>Hạn sử dụng</th>
                <th class="text-end">Tồn ban đầu</th>
                <th>Trạng thái Lô</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Data != null && Model.Data.Any())
            {
                @foreach (var item in Model.Data)
                {
                    bool isExpired = item.ExpiryDate.HasValue && item.ExpiryDate.Value < DateOnly.FromDateTime(DateTime.UtcNow);
                    bool isExpiringSoon = item.ExpiryDate.HasValue && !isExpired && item.ExpiryDate.Value <= DateOnly.FromDateTime(DateTime.UtcNow.AddDays(30));

                    <tr class="@(isExpired ? "table-danger" : (isExpiringSoon ? "table-warning" : ""))">
                        <td class="fw-bold">@item.LotNumber</td>
                        <td>@(item.ProductName ?? "---")</td>
                        <td>@(item.SupplierName ?? "---")</td>
                        <td>@(item.ExpiryDate?.ToString("dd/MM/yyyy") ?? "Không HSD")</td>
                        <td class="text-end fw-bold">@item.InitialQty</td>
                        <td>
                            @if (isExpired || item.Status == "Expired" || item.Status == "1")
                            {
                                <span class="badge bg-danger">EXPIRED</span>
                            }
                            else if (isExpiringSoon)
                            {
                                <span class="badge bg-warning text-dark">EXPIRING SOON</span>
                            }
                            else
                            {
                                <span class="badge bg-success">ACTIVE</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">
                        <i class="fa-solid fa-inbox fs-3 mb-2 d-block"></i>
                        Không tìm thấy dữ liệu lô hàng nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
