@model WMS.Web.Models.PagedResponseModel<WMS.Web.Models.ProductItemViewModel>
@{
    ViewData["Title"] = "Danh sách Sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">Danh sách Sản phẩm (SKUs)</h4>
        <p class="text-muted fs-7 mb-0">Quản lý danh mục hàng hóa, ngưỡng tồn tối thiểu & quy cách lưu kho</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Products/Categories" class="btn btn-outline-secondary btn-sm px-3 fw-semibold"><i class="fa-solid fa-tags me-1"></i> Danh mục</a>
    </div>
</div>

<!-- ──── Filter Panel ──── -->
<div class="card-wms p-3 mb-4">
    <form method="get" action="/Products" class="row g-2 align-items-center">
        <div class="col-12 col-md-8">
            <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm" placeholder="Tìm theo SKU, tên sản phẩm, mã vạch..." />
        </div>
        <div class="col-12 col-md-4 d-grid">
            <button type="submit" class="btn btn-sm btn-primary fw-semibold"><i class="fa-solid fa-magnifying-glass me-1"></i> Tìm kiếm</button>
        </div>
    </form>
</div>

<!-- ──── Products Table ──── -->
<div class="card-wms p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle fs-7 mb-0">
            <thead class="table-light">
                <tr>
                    <th>SKU</th>
                    <th>Tên sản phẩm</th>
                    <th>Mã vạch</th>
                    <th class="text-end">Min Stock</th>
                    <th class="text-end">Reorder Point</th>
                    <th>Theo Lô / HSD</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data != null && Model.Data.Any())
                {
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@item.SKU</td>
                            <td>
                                <div class="fw-semibold">@item.Name</div>
                            </td>
                            <td>@(item.Barcode ?? "---")</td>
                            <td class="text-end fw-bold text-danger">@item.MinStock</td>
                            <td class="text-end fw-bold text-muted">@item.ReorderPoint</td>
                            <td>
                                @if (item.IsBatchTracked)
                                {
                                    <span class="badge bg-info-subtle text-info border border-info me-1"><i class="fa-solid fa-check me-1"></i>Lô</span>
                                }
                                @if (item.IsExpiryTracked)
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning"><i class="fa-solid fa-clock me-1"></i>HSD</span>
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Tạm ngưng</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            <i class="fa-solid fa-inbox fs-3 mb-2 d-block"></i>
                            Chưa có sản phẩm nào trong hệ thống.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
