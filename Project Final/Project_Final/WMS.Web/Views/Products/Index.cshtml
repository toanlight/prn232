@{
    ViewData["Title"] = "Danh sách Sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">Danh sách Sản phẩm (SKUs)</h4>
        <p class="text-muted fs-7 mb-0">Quản lý danh mục hàng hóa, ngưỡng tồn tối thiểu & quy cách lưu kho</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Products/Categories" class="btn btn-outline-secondary btn-sm px-3 fw-semibold"><i class="fa-solid fa-tags me-1"></i> Danh mục</a>
        <a href="/Products/Create" class="btn btn-primary btn-sm px-3 fw-semibold"><i class="fa-solid fa-plus me-1"></i> Thêm Sản phẩm</a>
    </div>
</div>

<!-- ──── Filter Panel ──── -->
<div class="card-wms p-3 mb-4">
    <form method="get" action="/Products" class="row g-2 align-items-center">
        <div class="col-12 col-md-4">
            <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm" placeholder="Tìm theo SKU, tên sản phẩm, mã vạch..." />
        </div>
        <div class="col-6 col-md-3">
            <select class="form-select form-select-sm">
                <option value="">-- Tất cả danh mục --</option>
                <option value="1">Thực phẩm</option>
                <option value="2">Đồ uống</option>
                <option value="3">Hóa mỹ phẩm</option>
            </select>
        </div>
        <div class="col-6 col-md-3">
            <select class="form-select form-select-sm">
                <option value="">-- Trạng thái tồn kho --</option>
                <option value="low">Chỉ hiện tồn thấp (< Min)</option>
                <option value="active">Đang kinh doanh</option>
            </select>
        </div>
        <div class="col-12 col-md-2 d-grid">
            <button type="submit" class="btn btn-sm btn-primary fw-semibold"><i class="fa-solid fa-magnifying-glass me-1"></i> Tìm kiếm</button>
        </div>
    </form>
</div>

<!-- ──── Products Table ──── -->
<div class="card-wms p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle fs-7 mb-0">
            <thead class="table-light">
                <tr>
                    <th>SKU</th>
                    <th>Tên sản phẩm</th>
                    <th>Mã vạch</th>
                    <th>Danh mục</th>
                    <th>ĐVT</th>
                    <th class="text-end">Min Stock</th>
                    <th>Theo Lô / HSD</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <tr class="tr-low-stock">
                    <td class="fw-bold text-dark"><a href="/Products/Detail/1" class="text-decoration-none">SKU-FOOD-001</a></td>
                    <td>
                        <div class="fw-semibold">Sữa tươi tiệt trùng 1L</div>
                        <div class="text-muted fs-8">Fresh Whole Milk 1L</div>
                    </td>
                    <td>8934567890123</td>
                    <td><span class="badge bg-light text-dark border">Thực phẩm</span></td>
                    <td>Hộp</td>
                    <td class="text-end fw-bold text-danger">50</td>
                    <td>
                        <span class="badge bg-info-subtle text-info border border-info me-1"><i class="fa-solid fa-check me-1"></i>Lô</span>
                        <span class="badge bg-warning-subtle text-warning border border-warning"><i class="fa-solid fa-clock me-1"></i>HSD</span>
                    </td>
                    <td><span class="badge bg-success">Đang bán</span></td>
                    <td class="text-center">
                        <a href="/Products/Edit/1" class="btn btn-sm btn-light border text-primary" title="Sửa"><i class="fa-solid fa-pen-to-square"></i></a>
                        <a href="/Products/Detail/1" class="btn btn-sm btn-light border text-secondary" title="Chi tiết"><i class="fa-solid fa-eye"></i></a>
                    </td>
                </tr>
                <tr>
                    <td class="fw-bold text-dark"><a href="/Products/Detail/2" class="text-decoration-none">SKU-BEV-009</a></td>
                    <td>
                        <div class="fw-semibold">Nước ép cam nguyên chất 500ml</div>
                        <div class="text-muted fs-8">Pure Orange Juice</div>
                    </td>
                    <td>8934567890999</td>
                    <td><span class="badge bg-light text-dark border">Đồ uống</span></td>
                    <td>Chai</td>
                    <td class="text-end fw-bold text-muted">30</td>
                    <td>
                        <span class="badge bg-info-subtle text-info border border-info me-1"><i class="fa-solid fa-check me-1"></i>Lô</span>
                        <span class="badge bg-warning-subtle text-warning border border-warning"><i class="fa-solid fa-clock me-1"></i>HSD</span>
                    </td>
                    <td><span class="badge bg-success">Đang bán</span></td>
                    <td class="text-center">
                        <a href="/Products/Edit/2" class="btn btn-sm btn-light border text-primary" title="Sửa"><i class="fa-solid fa-pen-to-square"></i></a>
                        <a href="/Products/Detail/2" class="btn btn-sm btn-light border text-secondary" title="Chi tiết"><i class="fa-solid fa-eye"></i></a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
