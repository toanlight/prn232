@{
    ViewData["Title"] = "Chi tiết Sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">Chi tiết SKU: SKU-FOOD-001</h4>
        <p class="text-muted fs-7 mb-0">Sữa tươi tiệt trùng 1L • Danh mục: Thực phẩm</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Products/Edit/1" class="btn btn-primary btn-sm px-3 fw-semibold"><i class="fa-solid fa-pen me-1"></i> Chỉnh sửa</a>
        <a href="/Products" class="btn btn-outline-secondary btn-sm px-3 fw-semibold"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại</a>
    </div>
</div>

<div class="row g-3">
    <!-- Left Column: Info Cards -->
    <div class="col-12 col-md-4">
        <div class="card-wms p-4 mb-3">
            <h6 class="fw-bold mb-3 border-bottom pb-2 text-dark">Thông tin Sản phẩm</h6>
            <div class="fs-7">
                <div class="mb-2"><span class="text-muted">Mã SKU:</span> <strong class="text-dark">SKU-FOOD-001</strong></div>
                <div class="mb-2"><span class="text-muted">Mã vạch:</span> <span>8934567890123</span></div>
                <div class="mb-2"><span class="text-muted">Đơn vị tính:</span> <span class="badge bg-light text-dark border">Hộp</span></div>
                <div class="mb-2"><span class="text-muted">Tồn kho tối thiểu:</span> <strong class="text-danger">50 Hộp</strong></div>
                <div class="mb-2"><span class="text-muted">Quản lý lô:</span> <span class="badge bg-success">Có</span></div>
                <div class="mb-2"><span class="text-muted">Quản lý HSD:</span> <span class="badge bg-success">Có (Cảnh báo 30 ngày)</span></div>
            </div>
        </div>

        <div class="card-wms p-4">
            <h6 class="fw-bold mb-3 border-bottom pb-2 text-dark">Tóm tắt Tồn kho</h6>
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fs-7 text-muted">Tổng tồn thực tế:</span>
                <span class="fs-5 fw-bold text-primary">450</span>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fs-7 text-muted">Khả dụng (Available):</span>
                <span class="fs-5 fw-bold text-success">400</span>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <span class="fs-7 text-muted">Đã giữ chỗ (Reserved):</span>
                <span class="fs-5 fw-bold text-warning">50</span>
            </div>
        </div>
    </div>

    <!-- Right Column: Tabs (Stock by Location & Txn History) -->
    <div class="col-12 col-md-8">
        <div class="card-wms p-4">
            <ul class="nav nav-tabs border-bottom mb-3" id="productTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active fw-semibold fs-7" id="location-tab" data-bs-toggle="tab" data-bs-target="#location-pane">
                        <i class="fa-solid fa-location-dot me-1"></i> Vị trí lưu kho & Lô
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link fw-semibold fs-7" id="history-tab" data-bs-toggle="tab" data-bs-target="#history-pane">
                        <i class="fa-solid fa-history me-1"></i> Lịch sử Giao dịch
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="productTabsContent">
                <!-- Location Tab -->
                <div class="tab-pane fade show active" id="location-pane">
                    <table class="table table-hover align-middle fs-7">
                        <thead class="table-light">
                            <tr>
                                <th>Bin Code (Vị trí)</th>
                                <th>Số Lô</th>
                                <th>Hạn dùng</th>
                                <th class="text-end">Tồn kho</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong class="text-primary">WH-ZA-R1-S1-B01</strong></td>
                                <td>LOT-2026-0815</td>
                                <td>15/08/2026</td>
                                <td class="text-end fw-bold">250</td>
                            </tr>
                            <tr>
                                <td><strong class="text-primary">WH-ZA-R1-S2-B02</strong></td>
                                <td>LOT-2026-0910</td>
                                <td>10/09/2026</td>
                                <td class="text-end fw-bold">200</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- History Tab -->
                <div class="tab-pane fade" id="history-pane">
                    <table class="table table-hover align-middle fs-7">
                        <thead class="table-light">
                            <tr>
                                <th>Mã phiếu</th>
                                <th>Loại</th>
                                <th>Ngày giao dịch</th>
                                <th class="text-end">Số lượng</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>GRN-2026-0042</td>
                                <td><span class="badge bg-success">Nhập kho</span></td>
                                <td>22/07/2026 14:30</td>
                                <td class="text-end fw-bold text-success">+300</td>
                            </tr>
                            <tr>
                                <td>GDN-2026-0089</td>
                                <td><span class="badge bg-primary">Xuất kho</span></td>
                                <td>23/07/2026 10:15</td>
                                <td class="text-end fw-bold text-danger">-50</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
