@{
    ViewData["Title"] = "Quản lý Danh mục Sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">Danh mục Sản phẩm</h4>
        <p class="text-muted fs-7 mb-0">Quản lý phân cấp ngành hàng (Category Tree)</p>
    </div>
    <button class="btn btn-primary btn-sm px-3 fw-semibold" onclick="WMS.showToast('Mở modal thêm danh mục', 'info')">
        <i class="fa-solid fa-plus me-1"></i> Thêm Danh mục
    </button>
</div>

<div class="card-wms p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle fs-7">
            <thead class="table-light">
                <tr>
                    <th>Mã Danh mục</th>
                    <th>Tên Danh mục</th>
                    <th>Cấp cha</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-bold">CAT-FOOD</td>
                    <td><i class="fa-solid fa-folder me-2 text-warning"></i>Thực phẩm</td>
                    <td><span class="text-muted">Gốc (Root)</span></td>
                    <td><span class="badge bg-success">Hoạt động</span></td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-light border text-primary"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light border text-danger"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
                <tr>
                    <td class="fw-bold ps-4">CAT-MILK</td>
                    <td><i class="fa-solid fa-folder-open me-2 text-info"></i>Sữa & Chế phẩm từ sữa</td>
                    <td>Thực phẩm</td>
                    <td><span class="badge bg-success">Hoạt động</span></td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-light border text-primary"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light border text-danger"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
