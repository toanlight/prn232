@model WMS.Web.Models.ProductItemViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Chỉnh sửa Sản phẩm" : "Thêm mới Sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">@(isEdit ? "Cập nhật Sản phẩm: " + Model.SKU : "Tạo mới Sản phẩm")</h4>
        <p class="text-muted fs-7 mb-0">Cấu hình thông tin cơ bản, thuộc tính theo dõi lô & hạn sử dụng</p>
    </div>
    <a href="/Products" class="btn btn-outline-secondary btn-sm px-3 fw-semibold">
        <i class="fa-solid fa-arrow-left me-1"></i> Hủy & Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-lg-9">
        <form id="productForm">
            <div class="card-wms p-4 mb-4">
                <h6 class="fw-bold mb-3 border-bottom pb-2 text-primary"><i class="fa-solid fa-info-circle me-2"></i>1. Thông tin cơ bản</h6>
                
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label fs-7 fw-semibold">Mã SKU <span class="text-danger">*</span></label>
                        <input type="text" value="@Model.SKU" class="form-control form-control-sm" placeholder="VD: SKU-FOOD-001" required @(isEdit ? "readonly" : "") />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fs-7 fw-semibold">Mã vạch (Barcode)</label>
                        <input type="text" value="@Model.Barcode" class="form-control form-control-sm" placeholder="VD: 8934567890123" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label fs-7 fw-semibold">Tên sản phẩm (VI) <span class="text-danger">*</span></label>
                        <input type="text" value="@Model.Name" class="form-control form-control-sm" required />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fs-7 fw-semibold">Tên sản phẩm (EN)</label>
                        <input type="text" value="@Model.NameEn" class="form-control form-control-sm" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label fs-7 fw-semibold">Danh mục <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm" required>
                            <option value="1">Thực phẩm</option>
                            <option value="2">Đồ uống</option>
                            <option value="3">Hóa mỹ phẩm</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fs-7 fw-semibold">Đơn vị tính (UoM) <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm" required>
                            <option value="1">Hộp (BOX)</option>
                            <option value="2">Chai (BTL)</option>
                            <option value="3">Thùng (CTN)</option>
                            <option value="4">Kg (KG)</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="card-wms p-4 mb-4">
                <h6 class="fw-bold mb-3 border-bottom pb-2 text-primary"><i class="fa-solid fa-sliders me-2"></i>2. Cấu hình Tồn kho & Quản lý Lô / HSD</h6>
                
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label fs-7 fw-semibold">Tồn kho tối thiểu (Min Stock) <span class="text-danger">*</span></label>
                        <input type="number" step="0.01" value="@Model.MinStock" class="form-control form-control-sm" required />
                        <div class="form-text fs-8">Cảnh báo đỏ trên màn hình khi tồn kho dưới mức này</div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fs-7 fw-semibold">Điểm đặt hàng lại (Reorder Point)</label>
                        <input type="number" step="0.01" value="@Model.ReorderPoint" class="form-control form-control-sm" />
                    </div>

                    <div class="col-12 col-md-6">
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" id="IsBatchTracked" @(Model.IsBatchTracked ? "checked" : "") />
                            <label class="form-check-label fw-semibold fs-7" for="IsBatchTracked">Quản lý theo Số Lô (Batch/Lot)</label>
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" id="IsExpiryTracked" @(Model.IsExpiryTracked ? "checked" : "") />
                            <label class="form-check-label fw-semibold fs-7" for="IsExpiryTracked">Quản lý Hạn sử dụng (Expiry Date)</label>
                        </div>
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label fs-7 fw-semibold">Số ngày cảnh báo sắp hết hạn (Cảnh báo cam)</label>
                        <input type="number" value="@Model.ExpiryWarningDays" class="form-control form-control-sm" />
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a href="/Products" class="btn btn-secondary px-4">Hủy</a>
                <button type="button" onclick="saveProduct()" class="btn btn-primary px-4 fw-semibold">
                    <i class="fa-solid fa-floppy-disk me-1"></i> Lưu sản phẩm
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function saveProduct() {
        WMS.showToast('Lưu thông tin sản phẩm thành công!', 'success');
        setTimeout(() => location.href = '/Products', 1000);
    }
</script>
}
